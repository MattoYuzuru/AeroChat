upstream aerochat_web {
  server 127.0.0.1:18080;
}

upstream aerochat_gateway {
  server 127.0.0.1:18081;
}

server {
  listen 80;
  listen [::]:80;
  server_name aero.keykomi.com;

  location ^~ /.well-known/acme-challenge/ {
    root /var/www/certbot;
  }

  location = /healthz {
    access_log off;
    default_type text/plain;
    return 200 "healthy\n";
  }

  location = /readyz {
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_pass http://aerochat_gateway/readyz;
  }

  location / {
    return 308 https://aero.keykomi.com$request_uri;
  }
}

server {
  listen 443 ssl;
  listen [::]:443 ssl;
  http2 on;
  server_name aero.keykomi.com;

  ssl_certificate /etc/letsencrypt/live/aero.keykomi.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/aero.keykomi.com/privkey.pem;
  ssl_session_cache shared:SSL:10m;
  ssl_session_timeout 1d;
  ssl_protocols TLSv1.2 TLSv1.3;

  location = /healthz {
    access_log off;
    default_type text/plain;
    return 200 "healthy\n";
  }

  location = /readyz {
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_pass http://aerochat_gateway/readyz;
  }

  location /api/ {
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_pass http://aerochat_gateway/;
  }

  location / {
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_pass http://aerochat_web;
  }
}
