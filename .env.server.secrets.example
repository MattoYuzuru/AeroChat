# Версионируемый шаблон только для перечня обязательных server secrets.
# Реальные значения должны быть заданы только на VPS в невкоммиченном `.env.server.secrets`.
# `AERO_RTC_TURN_AUTH_SECRET` одновременно читает `aero-rtc-control` для time-based TURN credentials
# и repo-managed `turn` runtime в server compose.

POSTGRES_PASSWORD=replace-on-server
MINIO_ROOT_PASSWORD=replace-on-server
AERO_RTC_TURN_AUTH_SECRET=replace-on-server
