# Версионируемый runtime-шаблон для single-server self-host окружения.
# Здесь хранятся только несекретные server-параметры и выбор release tag.
# Реальные секреты должны жить только в невкоммиченном `.env.server.secrets` на VPS.

# Namespace registry-образов для application services.
AERO_IMAGE_NAMESPACE=ghcr.io/mattoyuzuru
# Тег релиза для `web`, `aero-gateway`, `aero-identity` и `aero-chat`.
AERO_IMAGE_TAG=edge

AERO_NGINX_HTTP_PORT=80

POSTGRES_DB=aerochat
POSTGRES_USER=aerochat

MINIO_ROOT_USER=aerochat

AERO_RUNTIME_LOG_LEVEL=info
AERO_SHUTDOWN_TIMEOUT=10s
AERO_DOWNSTREAM_TIMEOUT=5s
AERO_DIRECT_CHAT_TYPING_TTL=6s
AERO_DIRECT_CHAT_PRESENCE_TTL=30s

AERO_CORS_ALLOWED_ORIGINS=
