# Версионируемый runtime-шаблон для single-server self-host окружения.
# Здесь хранятся только несекретные server-параметры и выбор release tag.
# Реальные секреты должны жить только в невкоммиченном `.env.server.secrets` на VPS.

# Namespace registry-образов для application services.
AERO_IMAGE_NAMESPACE=ghcr.io/mattoyuzuru
# Тег релиза для `web`, `aero-gateway`, `aero-identity` и `aero-chat`.
AERO_IMAGE_TAG=edge

# Primary domain, который обслуживается shared `Traefik` в `k3s`.
AERO_EDGE_DOMAIN=aero.keykomi.com

# IP-адрес VPS, достижимый из pod'ов `Traefik`.
# Для final k3s / Traefik edge этот адрес должен совпадать с `EndpointSlice` в Kubernetes
# и не должен оставаться `127.0.0.1`.
AERO_SHARED_EDGE_HOST_IP=192.0.2.10

# High ports для compose upstream'ов, которые читает shared `Traefik`.
# `web` обслуживает `/`, `aero-gateway` обслуживает `/api`, `/healthz` и `/readyz`.
AERO_WEB_HOST_PORT=18080
AERO_GATEWAY_HOST_PORT=18081

POSTGRES_DB=aerochat
POSTGRES_USER=aerochat

MINIO_ROOT_USER=aerochat
MEDIA_S3_BUCKET=aerochat-attachments
MEDIA_S3_PUBLIC_ENDPOINT=
MEDIA_S3_PUBLIC_SECURE=true

AERO_RUNTIME_LOG_LEVEL=info
AERO_SHUTDOWN_TIMEOUT=10s
AERO_DATABASE_BOOTSTRAP_TIMEOUT=30s
AERO_DOWNSTREAM_TIMEOUT=5s
AERO_DIRECT_CHAT_TYPING_TTL=6s
AERO_DIRECT_CHAT_PRESENCE_TTL=30s
AERO_MEDIA_UPLOAD_INTENT_TTL=15m
AERO_MEDIA_MAX_UPLOAD_SIZE_BYTES=67108864

AERO_CORS_ALLOWED_ORIGINS=
