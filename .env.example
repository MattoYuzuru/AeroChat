POSTGRES_DB=aerochat
POSTGRES_USER=aerochat
POSTGRES_PASSWORD=aerochat
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MEDIA_S3_BUCKET=aerochat-attachments
# В `local/dev` браузер ходит прямо в локальный MinIO API.
# В `server/prod-like` browser-visible endpoint должен быть отдельным media host внутри зоны,
# например `https://media.keykomi.com`, а не nested host вида `https://media.aero.keykomi.com`.
# Если меняется `MINIO_API_PORT`, синхронно обнови и `MEDIA_S3_PUBLIC_ENDPOINT`.
MEDIA_S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MEDIA_S3_PUBLIC_SECURE=false
MEDIA_S3_CORS_ALLOWED_ORIGINS=http://127.0.0.1:8088,http://localhost:8088,http://localhost:5173

IDENTITY_PORT=8091
CHAT_PORT=8092
RTC_CONTROL_PORT=8093
GATEWAY_PORT=8080
WEB_PORT=8081
NGINX_PORT=8088
VITE_GATEWAY_BASE_URL=/api
VITE_RTC_ICE_SERVER_URLS=stun:stun.cloudflare.com:3478
AERO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:8088,http://localhost:8088,http://localhost:5173

AERO_DATABASE_BOOTSTRAP_TIMEOUT=30s
AERO_MEDIA_UPLOAD_INTENT_TTL=15m
AERO_MEDIA_ATTACHMENT_CLEANUP_INTERVAL=10m
AERO_MEDIA_UNATTACHED_ATTACHMENT_TTL=24h
AERO_MEDIA_DETACHED_ATTACHMENT_RETENTION=168h
AERO_MEDIA_ATTACHMENT_CLEANUP_BATCH_SIZE=100
AERO_MEDIA_MAX_UPLOAD_SIZE_BYTES=67108864
AERO_MEDIA_USER_QUOTA_BYTES=536870912
AERO_MAX_ACTIVE_GROUP_MEMBERSHIPS_PER_USER=100
AERO_RTC_SIGNAL_MAX_PAYLOAD_BYTES=16384
